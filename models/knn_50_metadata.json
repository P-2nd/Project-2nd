{
  "model": "KNeighborsClassifier",
  "purpose": "small-sample KNN model using EDA-preprocessed features",
  "input_path": "data/processed/churn_preprocessed_pct50.csv",
  "input_dataset": "pct50",
  "dataset_label": "50",
  "sample_rows": 30000,
  "features": [
    "Late_Payment_Count",
    "Monthly_Visits",
    "PT_Session_Count",
    "Start_Year",
    "Membership_Days",
    "Group_Class_Attendance",
    "Avg_Equipment_Wait_Time_Min",
    "Age",
    "Supplement_Usage_No Protein Supplements",
    "Cardio_Preference_Rowing",
    "Avg_Workout_Duration_Min"
  ],
  "target_column": "Churn",
  "target_meaning": {
    "0": "retained",
    "1": "churned"
  },
  "random_state": 42,
  "threshold_from_validation": 0.24622700140129478,
  "preprocessing": "Applied upstream in the input CSV; this script only median-imputes.",
  "artifacts": {
    "pipeline": "models/knn_50_pipeline.joblib",
    "metadata": "models/knn_50_metadata.json",
    "metrics": "data/evaluation/KNN_50_eval.json"
  }
}