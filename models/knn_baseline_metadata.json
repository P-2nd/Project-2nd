{
  "model": "KNeighborsClassifier",
  "purpose": "small-sample KNN baseline; not a full 1M-row final-model experiment",
  "input_path": "data/raw/gym_churn_1M_dataset.csv",
  "sample_rows": 30000,
  "features": [
    "Age",
    "Gender",
    "Membership_Type",
    "Monthly_Fee",
    "Monthly_Visits",
    "Avg_Workout_Duration_Min",
    "Peak_Hour_Preference",
    "Cardio_Preference",
    "Treadmill_Avg_Speed_Kmh",
    "Treadmill_Avg_Incline_Pct",
    "Group_Class_Attendance",
    "PT_Session_Count",
    "Supplement_Usage",
    "Avg_Equipment_Wait_Time_Min",
    "Late_Payment_Count",
    "Profile_Type",
    "membership_start_year",
    "membership_start_month",
    "membership_start_dayofweek"
  ],
  "target_column": "Churn",
  "target_meaning": {
    "0": "retained",
    "1": "churned"
  },
  "random_state": 42,
  "threshold_from_validation": 0.20736077902362487,
  "artifacts": {
    "pipeline": "models/knn_baseline_pipeline.joblib",
    "metrics": "data/evaluation/knn_baseline_metrics.json"
  }
}