{
  "model": "LogisticRegression",
  "purpose": "logistic-regression churn model using EDA-preprocessed features",
  "input_path": "data/processed/churn_preprocessed_full.csv",
  "input_dataset": "full",
  "dataset_label": "100",
  "sample_rows": 30000,
  "features": [
    "Age",
    "Monthly_Visits",
    "Avg_Workout_Duration_Min",
    "Group_Class_Attendance",
    "Avg_Equipment_Wait_Time_Min",
    "Late_Payment_Count",
    "Start_Year",
    "Start_Month",
    "Start_Weekday",
    "Membership_Days",
    "Cardio_Preference_Elliptical",
    "Cardio_Preference_No Preference",
    "Cardio_Preference_Rowing",
    "Cardio_Preference_Treadmill",
    "Supplement_Usage_Full Stack",
    "Supplement_Usage_No Protein Supplements",
    "Supplement_Usage_Pre-Workout",
    "Supplement_Usage_Whey Protein",
    "Profile_Type_Drop-out",
    "Profile_Type_Hardcore",
    "Profile_Type_Regular"
  ],
  "target_column": "Churn",
  "target_meaning": {
    "0": "retained",
    "1": "churned"
  },
  "random_state": 42,
  "threshold_from_validation": 0.39235532104450915,
  "preprocessing": "Applied upstream in the input CSV; this script imputes and scales numeric features within the training pipeline.",
  "artifacts": {
    "pipeline": "models/logistic_regression_100_pipeline.joblib",
    "metadata": "models/logistic_regression_100_metadata.json",
    "result_data": "data/results/result_data.json",
    "roc_source": "data/results/roc/logistic_regression_100_auc_roc.parquet"
  }
}